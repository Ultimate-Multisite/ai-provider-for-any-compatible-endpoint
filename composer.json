{
	"name": "ultimate-multisite/ai-services-connector",
	"description": "Registers a WordPress AI Client provider for Ollama, LM Studio, or any AI endpoint using the standard chat completions API format.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Ultimate Multisite Community",
			"homepage": "https://developer.developer.developer"
		}
	],
	"require": {
		"php": ">=7.4"
	},
	"autoload": {
		"classmap": [
			"inc/"
		]
	},
	"config": {
		"preferred-install": "dist",
		"sort-packages": true
	},
	"homepage": "https://github.com/Ultimate-Multisite/ai-services-connector",
	"support": {
		"issues": "https://github.com/Ultimate-Multisite/ai-services-connector/issues",
		"source": "https://github.com/Ultimate-Multisite/ai-services-connector"
	}
}
